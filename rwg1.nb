Cell["rwg6", "Subsubsection",
 CellChangeTimes->{{3.977949067410451*^9, 
  3.977949070477305*^9}},ExpressionUUID->"7071ebc5-ba17-4e68-ac78-\
223dd8837fde"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"currentNorm", "=", 
   RowBox[{"ConstantArray", "[", 
    RowBox[{"0", ",", "trangles"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"k", "=", "1"}], ",", 
   RowBox[{"k", "<=", "trangles"}], ",", 
   RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"i", "=", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], ";", "\[IndentingNewLine]", 
    
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"m", "=", "1"}], ",", 
      RowBox[{"m", "<=", "edgesTotal"}], ",", 
      RowBox[{"m", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"IE", "=", 
        RowBox[{
         RowBox[{"\[ScriptCapitalI]", "[", 
          RowBox[{"[", "m", "]"}], "]"}], 
         RowBox[{"edgeLength", "[", 
          RowBox[{"[", "m", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"trianglePlus", "[", 
           RowBox[{"[", "m", "]"}], "]"}], "==", "k"}], ",", 
         RowBox[{"i", "=", 
          RowBox[{"i", "+", 
           RowBox[{"IE", " ", 
            FractionBox[
             RowBox[{"rhoPlus", "[", 
              RowBox[{"[", "m", "]"}], "]"}], 
             RowBox[{"2", " ", 
              RowBox[{"area", "[", 
               RowBox[{"[", 
                RowBox[{"trianglePlus", "[", 
                 RowBox[{"[", "m", "]"}], "]"}], "]"}], "]"}]}]]}]}]}]}], 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"triangleMinus", "[", 
           RowBox[{"[", "m", "]"}], "]"}], "==", "k"}], ",", 
         RowBox[{"i", "=", 
          RowBox[{"i", "+", 
           RowBox[{"IE", " ", 
            FractionBox[
             RowBox[{"rhoMinus", "[", 
              RowBox[{"[", "m", "]"}], "]"}], 
             RowBox[{"2", " ", 
              RowBox[{"area", "[", 
               RowBox[{"[", 
                RowBox[{"triangleMinus", "[", 
                 RowBox[{"[", "m", "]"}], "]"}], "]"}], "]"}]}]]}]}]}]}], 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"currentNorm", "[", 
         RowBox[{"[", "k", "]"}], "]"}], "=", 
        RowBox[{"Abs", "[", 
         RowBox[{"i", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}]}]}]}], "]"}]}]}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.9779491542292137`*^9, 3.97794915712773*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"cac4f5e2-6591-4fb3-9991-fea474c52d78"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"k", "=", "15"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x0", "=", 
   RowBox[{"Min", "[", 
    RowBox[{"p", "[", 
     RowBox[{"[", 
      RowBox[{";;", ",", "1"}], "]"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
